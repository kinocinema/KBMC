{
  "entities": {
    "Doctor": {
      "title": "Doctor",
      "description": "A doctor profile in the hospital.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "designation": { "type": "string" },
        "qualification": { "type": "string" },
        "department": { "type": "string" },
        "clinicSuite": { "type": "string" },
        "isFemale": { "type": "boolean" },
        "bio": { "type": "string" },
        "focus": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "status": { "type": "string" },
        "phone": { "type": "string" },
        "operationHours": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "string" },
              "time": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "department"]
    },
    "NewsArticle": {
      "title": "News Article",
      "description": "A news or gallery item.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["title", "content", "date"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global settings for the website.",
      "type": "object",
      "properties": {
        "emergencyPhone": { "type": "string" },
        "mainLine": { "type": "string" },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" }
      }
    },
    "User": {
      "title": "User",
      "description": "A user of the admin system.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "editor"] }
      },
      "required": ["email", "role"]
    },
    "Service": {
      "title": "Service",
      "description": "A medical service or centre of excellence.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "description"]
    },
    "Career": {
      "title": "Career",
      "description": "A job posting.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "department": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "requirements": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "datePosted": { "type": "string" }
      },
      "required": ["title", "department", "type"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A contact form submission.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read"] }
      },
      "required": ["name", "message", "date"]
    },
    "Page": {
      "title": "Page",
      "description": "Content for a specific page.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "heading": { "type": "string" },
              "body": { "type": "string" },
              "imageUrl": { "type": "string" }
            }
          }
        }
      },
      "required": ["title"]
    },
    "Menu": {
      "title": "Menu",
      "description": "Navigation menu structure.",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "links": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "path": { "type": "string" },
                    "content": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Collection of doctors."
    },
    "/news/{newsId}": {
      "schema": "NewsArticle",
      "description": "Collection of news articles."
    },
    "/settings/{settingId}": {
      "schema": "SiteSettings",
      "description": "Global site settings."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Admin users."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Hospital services."
    },
    "/careers/{careerId}": {
      "schema": "Career",
      "description": "Job postings."
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Contact form submissions."
    },
    "/pages/{pageId}": {
      "schema": "Page",
      "description": "Page content."
    }
  }
}
